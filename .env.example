ENV=dev

COMPOSE_PATH_SEPARATOR=:
COMPOSE_PROJECT_NAME=xflow

# Docs
DOCS_PORT=5000

# API Gateway
API_GATEWAY_PORT=8080

# Auth Service
AUTH_SERVICE_PORT=8081
EXPIRATION_MS=900000
REFRESH_EXPIRATION_MS=8640000000
AUTH_MAX_FAILED_ATTEMPTS=3
AUTH_LOCKOUT_DURATION_MS=1800000
AUTH_ANON_MAX_ATTEMPTS=5
AUTH_ANON_LOCKOUT_DURATION_MS=3600000

# PostgreSQL
POSTGRES_DB=xflow
POSTGRES_USER=xflow
POSTGRES_PASSWORD=xflow
POSTGRES_PORT=5432
POSTGRES_PORT_EXT=5433

# Redis
REDIS_PORT=6379

# Mailpit
MAILPIT_SMTP_PORT=8025
MAILPIT_WEB_UI_PORT=1025