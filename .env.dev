ENV=dev

COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml

# API Gateway
API_GATEWAY_PORT=8080

# Auth Service
AUTH_SERVICE_PORT=8081

# PostgreSQL
POSTGRES_DB=xflow-dev
